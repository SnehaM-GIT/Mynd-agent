# ── Required ──────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Optional: LLM Model ──────────────────────────────────────────
# MYND_LLM_MODEL=llama-3.3-70b-versatile

# ── Optional: Timezone (defaults to Asia/Kolkata) ─────────────────
# MYND_TIMEZONE=Asia/Kolkata
# MYND_UTC_OFFSET=+05:30

# ── Optional: User Identity ──────────────────────────────────────
# MYND_USER_ID=local_user

# ── Optional: Microsoft Calendar (Azure app registration needed) ─
# MICROSOFT_CLIENT_ID=your_azure_client_id_here
